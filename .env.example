# Copy to .env and fill in your values
# Required for OpenAI ASR/LLM backends
OPENAI_API_KEY=sk-...

# Required for Anthropic LLM backend
ANTHROPIC_API_KEY=sk-ant-...

# Backend selection (google|openai|local_whisper|mock)
ASR_BACKEND=google

# Backend selection (openai|anthropic|mock)
LLM_BACKEND=openai

# Backend selection (edge_tts|pyttsx3|mock)
TTS_BACKEND=edge_tts

# Optional: override the assistant system prompt
# SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise.
